# ── Global behaviour ─────────────────────────────────────────────────────────
OBSERVABILITY_MODE=full              # full | partial | dark
PII_MASKING_MODE=full                # full | pipeline_level | app_level | disabled
LOG_LEVEL=INFO
SERVICE_VERSION=1.0.0
DEPLOYMENT_ENV=training

# ── License ──────────────────────────────────────────────────────────────────
# Without a valid LICENSE_KEY the stack refuses to start. To obtain one:
#   1. make fingerprint           # prints THIS machine's hardware fingerprint
#   2. email the fingerprint to your trainer
#   3. paste the JWT they send back here:
LICENSE_KEY=eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJjb2hvcnRAYmFua29ic2VydmUzNjAudHJhaW5pbmciLCJodyI6IioiLCJ0aWVyIjoic3R1ZGVudCIsImZlYXR1cmVzIjpbImFsbCJdLCJqdGkiOiI0NDY4OTRhNS00NDg5LTQ5ZDctOGE2Mi0zM2FkYTYxY2MwNjMiLCJpc3MiOiJiYW5rb2JzZXJ2ZTM2MCIsImV4cCI6MTc5ODgwMzM0MSwiaWF0IjoxNzgzMjUxMzQxfQ.RuC_RlHu6yHRrLglVd_ExZynHq1Lb9nlYruoyFfEO5Hk1uU7PU9z5b_F9F7nzW3Hj3MHVJMj5MhGOjYYZWeiAQ
# The Makefile populates these from the host before bringing the stack up.
# You normally don't need to touch them.
LICENSE_CHECKER_URL=http://license-checker:7743

# ── OTel ─────────────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0
# OTEL_SERVICE_NAME and OTEL_RESOURCE_ATTRIBUTES are set per-service in docker-compose.services.yml

# ── Oracle XE (core banking primary) ─────────────────────────────────────────
ORACLE_HOST=oracle
ORACLE_PORT=1521
ORACLE_SID=XE
ORACLE_URL=jdbc:oracle:thin:@oracle:1521:XE
ORACLE_USER=BANKOBS_CORE
ORACLE_PASSWORD=Training123!
ORACLE_SYSTEM_PASSWORD=Training123!

# ── PostgreSQL (identity + retail + license portal) ──────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=bankobs
POSTGRES_PASSWORD=Training123!
POSTGRES_DB=bankobs_identity
POSTGRES_URL=postgresql://bankobs:Training123!@postgres:5432/bankobs_identity

# ── MongoDB (fraud rules, AML cases, audit, loan apps) ───────────────────────
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_USER=bankobs
MONGODB_PASSWORD=Training123!
MONGODB_URL=mongodb://bankobs:Training123!@mongodb:27017/bankobs?authSource=admin

# ── Redis (cache + rate limit + OTP + sessions) ──────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ── Cassandra (UPI transactions) ─────────────────────────────────────────────
CASSANDRA_HOSTS=cassandra:9042
CASSANDRA_KEYSPACE=bankobs_payments
CASSANDRA_DC=datacenter1

# ── Elasticsearch (audit, statement search) ──────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX_PREFIX=bankobs

# ── Kafka (KRaft, no ZK) ─────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SCHEMA_REGISTRY_URL=http://schema-registry:8081

# ── RabbitMQ (notification dispatch) ─────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# ── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=bankobs-training-jwt-secret-2024
JWT_ISSUER=bankobserve360
JWT_EXPIRY_SECONDS=1800

# ── Identity Vault encryption key (AES-256-GCM, must be 32 bytes) ────────────
VAULT_ENCRYPTION_KEY=bankobs-vault-encryption-key-32!

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ── Load runner ──────────────────────────────────────────────────────────────
LOADRUNNER_BASE_URL=http://gateway-service:8000
LOADRUNNER_API_PORT=8090
LOADRUNNER_METRICS_PORT=9090
